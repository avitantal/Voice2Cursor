# Environment
.env

# Offset state
offset.txt

# Logs
logs/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# PyInstaller — keep Voice2Cursor.spec (source), exclude build output
dist/
build/
*.exe

# IDE
.vscode/
.idea/

# Temp files
_task.xml

# Local working dir (build/test/diagnostic scripts)
.qa/

# Distribution zips (live in releases/ for backup; loose zips at root are transient)
Voice2Cursor_v*.zip

# Archived release binaries — preserved locally only, never committed
releases/*/Voice2Cursor.exe
releases/*/Voice2Cursor_v*.zip

# Per-user runtime state — not part of the source tree
bots.json
bots.json.bak

# Temp copies left if a build is interrupted between preserve and restore
_preserved_*
